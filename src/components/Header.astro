---
import { site } from '../data/site';
import Icon from './Icon.astro';

const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="header">
  <div class="container header-inner">
    <a class="brand" href="#top">{site.name}</a>

    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle color theme">
      <Icon name="sun" size={18} class="icon-sun" />
      <Icon name="moon" size={18} class="icon-moon" />
    </button>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next =
      document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 60px;
  }
  .brand {
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }
  .nav {
    display: none;
    gap: 1.4rem;
    margin-inline-start: auto;
  }
  .nav a {
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .theme-toggle {
    margin-inline-start: auto;
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 0.55rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    cursor: pointer;
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (min-width: 720px) {
    .nav {
      display: flex;
    }
    .theme-toggle {
      margin-inline-start: 0;
    }
  }
  /* Show the icon for the theme you can switch *to*.
     Fully global because the SVGs now live in the Icon component's scope. */
  :global(:root[data-theme='light'] .icon-sun),
  :global(:root[data-theme='dark'] .icon-moon) {
    display: none;
  }
</style>
