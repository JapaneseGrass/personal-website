---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order
);
---

<section id="projects" class="section">
  <div class="container reveal">
    <p class="eyebrow">03 — Projects</p>
    <h2 class="section-title">Things I’ve built</h2>
    <p class="section-lead">
      A selection of projects that show how I think and what I can ship.
    </p>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class={`project-card reveal${project.data.featured ? ' is-featured' : ''}`}>
            {project.data.featured && <span class="badge">Featured</span>}
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>

            {project.data.tech.length > 0 && (
              <ul class="chip-list project-tech">
                {project.data.tech.map((t) => (
                  <li class="chip">{t}</li>
                ))}
              </ul>
            )}

            <div class="project-links">
              {project.data.repo && (
                <a href={project.data.repo} target="_blank" rel="noopener">
                  <Icon name="github" size={18} /> Code
                </a>
              )}
              {project.data.demo && (
                <a href={project.data.demo} target="_blank" rel="noopener">
                  <Icon name="external" size={18} /> Live demo
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    padding: 1.4rem;
    box-shadow: var(--shadow);
    transition: transform 0.12s ease, border-color 0.15s ease;
  }
  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .is-featured {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }
  .badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
  }
  .project-title {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
    padding-right: 4.5rem;
  }
  .project-desc {
    color: var(--text-muted);
    font-size: 0.96rem;
    flex: 1;
  }
  .project-tech {
    margin: 0.5rem 0 1rem;
  }
  .project-links {
    display: flex;
    gap: 1.2rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .project-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .project-links a:hover {
    text-decoration: none;
    color: var(--accent-hover);
  }
</style>
