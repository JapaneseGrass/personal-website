---
import { site } from '../data/site';
import Icon from './Icon.astro';

const resumeHref = `${import.meta.env.BASE_URL}${site.resume}`;
---

<section id="top" class="hero">
  <div class="container hero-inner">
    <p class="eyebrow reveal">Hi, my name is</p>
    <h1 class="hero-name reveal">{site.name}.</h1>
    <h2 class="hero-role reveal">{site.role} — based in {site.location}.</h2>
    <p class="hero-tagline reveal">{site.tagline}</p>

    <div class="hero-actions reveal">
      <a class="btn btn-primary" href="#projects">
        View my work <Icon name="arrow" size={18} />
      </a>
      <a class="btn btn-ghost" href={resumeHref} download>
        Download résumé <Icon name="download" size={18} />
      </a>
    </div>

    <ul class="hero-socials reveal">
      {
        site.socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener">
              <Icon name={s.icon} />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 60px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
        60% 50% at 15% 0%,
        var(--accent-soft) 0%,
        transparent 60%
      ),
      radial-gradient(40% 40% at 100% 100%, var(--accent-soft) 0%, transparent 70%);
    opacity: 0.7;
    z-index: -1;
  }
  .hero-inner {
    padding-block: 3rem;
  }
  .hero-name {
    font-size: clamp(2.5rem, 9vw, 4.5rem);
    margin: 0;
  }
  .hero-role {
    font-size: clamp(1.3rem, 5vw, 2.2rem);
    color: var(--text-muted);
    margin: 0.25rem 0 1.5rem;
    font-weight: 600;
  }
  .hero-tagline {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 52ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }
  .hero-socials {
    display: flex;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
  }
  .hero-socials a {
    color: var(--text-muted);
    display: inline-flex;
  }
  .hero-socials a:hover {
    color: var(--accent);
  }
  /* Stagger the reveal of hero children */
  .reveal:nth-child(1) { transition-delay: 0.05s; }
  .reveal:nth-child(2) { transition-delay: 0.12s; }
  .reveal:nth-child(3) { transition-delay: 0.19s; }
  .reveal:nth-child(4) { transition-delay: 0.26s; }
  .reveal:nth-child(5) { transition-delay: 0.33s; }
  .reveal:nth-child(6) { transition-delay: 0.40s; }
</style>
